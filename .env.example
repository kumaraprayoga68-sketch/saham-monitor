# Copy file ini jadi ".env" lalu isi dengan data lu sendiri.
# Cara dapat token: chat @BotFather di Telegram -> /newbot -> ikutin instruksi.
# Cara dapat chat_id: chat bot lu sekali, lalu buka:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# cari angka di bagian "chat":{"id": ... }

TELEGRAM_BOT_TOKEN=isi_token_bot_lu_disini
TELEGRAM_CHAT_ID=isi_chat_id_lu_disini
